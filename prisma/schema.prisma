generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteConfig {
  id                Int                @id @default(1)
  heroTitleKo       String
  heroTitleEn       String
  heroDescriptionKo String             @db.Text
  heroDescriptionEn String             @db.Text
  heroImageUrl      String?
  heroFontSize      Int                @default(56)
  storyTitleKo      String             @default("산업 현장과 공정 목적에 맞춘 광학 설계")
  storyTitleEn      String             @default("Optical engineering aligned with industrial processes")
  storyBodyKo       String             @db.Text
  storyBodyEn       String             @db.Text
  storyFontSize     Int                @default(17)
  seoTitleKo        String
  seoTitleEn        String
  seoDescriptionKo  String             @db.Text
  seoDescriptionEn  String             @db.Text
  heroImageHistory  HeroImageHistory[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model HeroImageHistory {
  id           Int        @id @default(autoincrement())
  siteConfigId Int
  imageUrl     String
  createdAt    DateTime   @default(now())
  siteConfig   SiteConfig @relation(fields: [siteConfigId], references: [id], onDelete: Cascade)
}

model Application {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  titleKo          String
  titleEn          String
  summaryKo        String   @db.Text
  summaryEn        String   @db.Text
  imageUrl         String?
  bulletsKo        Json
  bulletsEn        Json
  sortOrder        Int      @default(0)
  published        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Product {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  displayOrder     Int      @default(0)
  nameKo           String
  nameEn           String
  heroEyebrowKo    String?
  heroEyebrowEn    String?
  heroTitleKo      String?
  heroTitleEn      String?
  heroLeadKo       String?  @db.Text
  heroLeadEn       String?  @db.Text
  heroBgImageUrl   String?
  heroBgOpacity    Float?   @default(0.9)
  summaryKo        String   @db.Text
  summaryEn        String   @db.Text
  contentKo        String   @db.Text
  contentEn        String   @db.Text
  featuresKo       Json?
  featuresEn       Json?
  applicationsKo   Json?
  applicationsEn   Json?
  specsKo          Json?
  specsEn          Json?
  imageUrl         String?
  seoTitleKo       String?
  seoTitleEn       String?
  seoDescriptionKo String?  @db.Text
  seoDescriptionEn String?  @db.Text
  published        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Resource {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  displayIndex     Int      @default(1)
  titleKo          String
  titleEn          String
  excerptKo        String   @db.Text
  excerptEn        String   @db.Text
  bodyKo           String   @db.Text
  bodyEn           String   @db.Text
  fileUrl          String?
  publishedAt      DateTime @default(now())
  published        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Inquiry {
  id               Int           @id @default(autoincrement())
  company          String?
  name             String
  email            String
  phone            String?
  message          String        @db.Text
  locale           String
  status           InquiryStatus @default(RECEIVED)
  internalNote     String?       @db.Text
  replySubject     String?
  replyBody        String?       @db.Text
  replySentAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model AdminAccount {
  id             Int              @id @default(autoincrement())
  username       String           @unique
  passwordHash   String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  sessions       AdminSession[]
  accessLogs     AdminAccessLog[]
}

model AdminSession {
  id           Int          @id @default(autoincrement())
  token        String       @unique
  adminId      Int
  expiresAt    DateTime
  createdAt    DateTime     @default(now())
  admin        AdminAccount @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model AdminAccessLog {
  id           Int          @id @default(autoincrement())
  adminId      Int?
  username     String
  ipAddress    String?
  userAgent    String?
  success      Boolean      @default(false)
  createdAt    DateTime     @default(now())
  admin        AdminAccount? @relation(fields: [adminId], references: [id], onDelete: SetNull)
}

model VisitLog {
  id           Int      @id @default(autoincrement())
  visitDate    DateTime
  visitorKey   String
  locale       String?
  createdAt    DateTime @default(now())

  @@unique([visitDate, visitorKey])
}

enum InquiryStatus {
  RECEIVED
  REVIEWING
  REPLIED
}
