generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteConfig {
  id               Int      @id @default(1)
  heroTitleKo      String
  heroTitleEn      String
  heroDescriptionKo String   @db.Text
  heroDescriptionEn String   @db.Text
  storyBodyKo      String    @db.Text
  storyBodyEn      String    @db.Text
  seoTitleKo       String
  seoTitleEn       String
  seoDescriptionKo String    @db.Text
  seoDescriptionEn String    @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Application {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  titleKo          String
  titleEn          String
  summaryKo        String   @db.Text
  summaryEn        String   @db.Text
  imageUrl         String?
  bulletsKo        Json
  bulletsEn        Json
  sortOrder        Int      @default(0)
  published        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Product {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  nameKo           String
  nameEn           String
  summaryKo        String   @db.Text
  summaryEn        String   @db.Text
  contentKo        String   @db.Text
  contentEn        String   @db.Text
  imageUrl         String?
  seoTitleKo       String?
  seoTitleEn       String?
  seoDescriptionKo String?  @db.Text
  seoDescriptionEn String?  @db.Text
  published        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Resource {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  titleKo          String
  titleEn          String
  excerptKo        String   @db.Text
  excerptEn        String   @db.Text
  bodyKo           String   @db.Text
  bodyEn           String   @db.Text
  fileUrl          String?
  published        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Inquiry {
  id               Int      @id @default(autoincrement())
  company          String?
  name             String
  email            String
  phone            String?
  message          String   @db.Text
  locale           String
  status           InquiryStatus @default(RECEIVED)
  createdAt        DateTime @default(now())
}

enum InquiryStatus {
  RECEIVED
  REVIEWING
  REPLIED
}
